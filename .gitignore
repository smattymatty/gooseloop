__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.venv/
venv/
build/
dist/
.env

# Runtime output dirs — session bookkeeping and engine artifacts.
# NOTE: .gitignore has no inline comments; a trailing "# ..." becomes part of
# the pattern and silently matches nothing. Keep every comment on its own line.
reviews/
# present only while a run is in flight (PROTOCOL section 13)
run.lock
# git-recap engine output (configurable; default name)
journal/
# git-recap cross-run watermarks (machine-written)
git-recap.state.json
# hello-world engine output
greetings/
# hello-world guest list: user-procured; the committed template is names.example.txt
names.txt
# doc-drift patch drafts (configurable; default name)
doc-drift-drafts/
# doc-drift cross-run memory (machine-written)
doc-map.state.json

# doc-drift map: the operator's real map points at their own repos + live URLs,
# so it's private. The committed template is doc-map.example.toml.
doc-map.toml
!doc-map.example.toml

# Project config: the operator's real config points at their own repos and
# carries their author identity. The committed template is gooseloop.example.toml.
gooseloop.toml
!gooseloop.example.toml

# Recipe overlays + goose state.
*.local.yaml
.goose/

# Editor + OS noise.
*.swp
.DS_Store

# Per-machine Claude Code local settings.
.claude/settings.local.json
